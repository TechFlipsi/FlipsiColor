<Window x:Class="FlipsiColor.LoadingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding ., Converter={StaticResource Loc}, ConverterParameter='Loading.Titel'}"
        Width="500" Height="320"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        Background="#0F1117">
    <Border Background="#0F1117" CornerRadius="12" Padding="32">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <!-- Logo -->
            <TextBlock Text="FlipsiColor" FontSize="28" FontWeight="Bold" Foreground="#E8E8E8"
                       HorizontalAlignment="Center" Margin="0,0,0,8"/>
            <TextBlock Text="{Binding ., Converter={StaticResource Loc}, ConverterParameter='Loading.KIModelleHerunterladen'}" FontSize="14" Foreground="#8B8FA3"
                       HorizontalAlignment="Center" Margin="0,0,0,24"/>

            <!-- Fortschrittsbalken -->
            <ProgressBar Width="400" Height="8"
                         Minimum="0" Maximum="100" Value="{Binding Fortschritt}"
                         Foreground="#0EA5E9" Background="#252836"
                         HorizontalAlignment="Center" Margin="0,0,0,12"/>

            <!-- Status-Text -->
            <TextBlock Text="{Binding StatusText}" FontSize="12" Foreground="#8B8FA3"
                       HorizontalAlignment="Center" Margin="0,0,0,16"/>

            <!-- Modell-Liste -->
            <ItemsControl x:Name="ModelList" Width="400" HorizontalAlignment="Center"
                          ItemsSource="{Binding Modelle}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="0,4">
                            <TextBlock Text="⏳" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding Name}" FontSize="12" Foreground="#8B8FA3"
                                       VerticalAlignment="Center" Width="200"/>
                            <TextBlock Text="{Binding Status}" FontSize="12" Foreground="#8B8FA3"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </Border>
</Window>