<Window x:Class="FlipsiColor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:FlipsiColor.UI"
        Title="{Binding Title}" 
        Width="1200" Height="800"
        WindowStartupLocation="CenterScreen"
        MinWidth="800" MinHeight="600">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <!-- ═══ Sidebar ═══ -->
        <Border Grid.Column="0" Background="{DynamicResource BgSecondaryBrush}" 
                BorderBrush="{DynamicResource BorderPrimaryBrush}" BorderThickness="0,0,1,0">
            <StackPanel Margin="16">
                <!-- Logo -->
                <TextBlock Text="FlipsiColor" FontSize="24" FontWeight="Bold" 
                           Foreground="{DynamicResource AccentPrimaryBrush}" Margin="0,0,0,24"/>

                <!-- Modus -->
                <TextBlock Text="Modus" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <ComboBox SelectedItem="{Binding AktuellerModus}" Margin="0,0,0,16">
                    <ComboBoxItem Content="Ask"/>
                    <ComboBoxItem Content="SmartLearn"/>
                    <ComboBoxItem Content="Turbo"/>
                </ComboBox>

                <!-- Intensität -->
                <TextBlock Text="Intensität" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <ComboBox SelectedIndex="{Binding IntensitaetIndex}" Margin="0,0,0,16">
                    <ComboBoxItem Content="Leicht"/>
                    <ComboBoxItem Content="Mittel"/>
                    <ComboBoxItem Content="Stark"/>
                </ComboBox>

                <!-- Buttons -->
                <Button Content="📁 Bild öffnen" Command="{Binding BildOeffnenCommand}" Margin="0,0,0,8"/>
                <Button Content="▶ Pipeline starten" Command="{Binding PipelineAusfuehrenCommand}" Margin="0,0,0,8"/>
                <Button Content="↺ Zurücksetzen" Command="{Binding ZuruecksetzenCommand}" Margin="0,0,0,8"/>

                <!-- GPU Info -->
                <Border Background="{DynamicResource BgTertiaryBrush}" CornerRadius="8" Padding="12" Margin="0,16,0,0">
                    <StackPanel>
                        <TextBlock Text="GPU" FontWeight="SemiBold" FontSize="12"/>
                        <TextBlock Text="{Binding GpuName}" FontSize="11" 
                                   Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                        <Ellipse Width="8" Height="8" Margin="0,4,0,0" HorizontalAlignment="Left">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="{DynamicResource SuccessBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding GpuVerfuegbar}" Value="False">
                                            <Setter Property="Fill" Value="{DynamicResource WarningBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                    </StackPanel>
                </Border>

                <!-- Update -->
                <Border Background="{DynamicResource BgTertiaryBrush}" CornerRadius="8" Padding="12" Margin="0,8,0,0"
                        Visibility="{Binding UpdateVerfuegbar, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <TextBlock Text="Update verfügbar!" FontWeight="SemiBold" 
                                   Foreground="{DynamicResource AccentSecondaryBrush}"/>
                        <TextBlock Text="{Binding NeueVersion}" FontSize="11"/>
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <Button Content="Installieren" Command="{Binding UpdateStartenCommand}" 
                                    Padding="8,4" Margin="0,0,8,0" FontSize="11"/>
                            <Button Content="Ignorieren" Command="{Binding UpdateIgnorierenCommand}" 
                                    Padding="8,4" FontSize="11" Background="{DynamicResource BgTertiaryBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Theme -->
                <StackPanel Margin="0,16,0,0">
                    <TextBlock Text="Theme" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="☀ Light" Command="{Binding ThemeWechselnCommand}" 
                                CommandParameter="Light" Padding="8,4" Margin="0,0,4,0" FontSize="11"/>
                        <Button Content="🌙 Dark" Command="{Binding ThemeWechselnCommand}" 
                                CommandParameter="Dark" Padding="8,4" Margin="0,0,4,0" FontSize="11"/>
                        <Button Content="🖥 System" Command="{Binding ThemeWechselnCommand}" 
                                CommandParameter="System" Padding="8,4" FontSize="11"/>
                    </StackPanel>
                </StackPanel>

                <!-- Status -->
                <TextBlock Text="{Binding StatusText}" FontSize="11" 
                           Foreground="{DynamicResource TextSecondaryBrush}" 
                           VerticalAlignment="Bottom" Margin="0,24,0,0"/>
            </StackPanel>
        </Border>

        <!-- ═══ Canvas Area ═══ -->
        <Border Grid.Column="1" Background="{DynamicResource BgPrimaryBrush}">
            <Grid>
                <!-- Bild-Vorschau -->
                <Image Source="{Binding BildPfad}" Stretch="Uniform" 
                       VerticalAlignment="Center" HorizontalAlignment="Center"
                       Margin="16"/>

                <!-- Platzhalter wenn kein Bild geladen -->
                <TextBlock Text="Bild öffnen oder hierher ziehen" 
                           FontSize="18" Foreground="{DynamicResource TextSecondaryBrush}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Visibility="{Binding BildGeladen, Converter={StaticResource InverseBoolToVis}}"/>
            </Grid>
        </Border>

        <!-- ═══ Adjustments Panel ═══ -->
        <Border Grid.Column="2" Background="{DynamicResource BgSecondaryBrush}" 
                BorderBrush="{DynamicResource BorderPrimaryBrush}" BorderThickness="1,0,0,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="16">
                    <TextBlock Text="Korrektur" FontSize="18" FontWeight="Bold" Margin="0,0,0,16"/>

                    <!-- Belichtung -->
                    <TextBlock Text="Belichtung" Margin="0,0,0,4"/>
                    <Slider Minimum="-100" Maximum="100" Value="{Binding Belichtung}" Margin="0,0,0,12"/>

                    <!-- Kontrast -->
                    <TextBlock Text="Kontrast" Margin="0,0,0,4"/>
                    <Slider Minimum="-100" Maximum="100" Value="{Binding Kontrast}" Margin="0,0,0,12"/>

                    <!-- Sättigung -->
                    <TextBlock Text="Sättigung" Margin="0,0,0,4"/>
                    <Slider Minimum="-100" Maximum="100" Value="{Binding Saettigung}" Margin="0,0,0,12"/>

                    <!-- Vibranz -->
                    <TextBlock Text="Vibranz" Margin="0,0,0,4"/>
                    <Slider Minimum="-100" Maximum="100" Value="{Binding Vibranz}" Margin="0,0,0,12"/>

                    <!-- Lichter -->
                    <TextBlock Text="Lichter" Margin="0,0,0,4"/>
                    <Slider Minimum="-100" Maximum="100" Value="{Binding Lichter}" Margin="0,0,0,12"/>

                    <!-- Schatten -->
                    <TextBlock Text="Schatten" Margin="0,0,0,4"/>
                    <Slider Minimum="-100" Maximum="100" Value="{Binding Schatten}" Margin="0,0,0,12"/>

                    <!-- Schärfe -->
                    <TextBlock Text="Schärfe" Margin="0,0,0,4"/>
                    <Slider Minimum="0" Maximum="100" Value="{Binding Schaerfe}" Margin="0,0,0,12"/>

                    <!-- Luminanz-Rauschen -->
                    <TextBlock Text="Rauschen (Luma)" Margin="0,0,0,4"/>
                    <Slider Minimum="0" Maximum="100" Value="{Binding RauschenLuma}" Margin="0,0,0,12"/>

                    <!-- Chrominanz-Rauschen -->
                    <TextBlock Text="Rauschen (Chroma)" Margin="0,0,0,4"/>
                    <Slider Minimum="0" Maximum="100" Value="{Binding RauschenChroma}" Margin="0,0,0,12"/>

                    <!-- Objektivkorrektur -->
                    <CheckBox Content="Objektivkorrektur" IsChecked="{Binding Objektivkorrektur}" Margin="0,8,0,0"/>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>