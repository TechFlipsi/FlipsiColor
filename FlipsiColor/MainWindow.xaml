<Window x:Class="FlipsiColor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:FlipsiColor.UI"
        xmlns:conv="clr-namespace:FlipsiColor"
        Title="{Binding Title}"
        Width="1280" Height="800"
        WindowStartupLocation="CenterScreen"
        MinWidth="900" MinHeight="600"
        AllowDrop="True"
        PreviewDragEnter="OnWindowPreviewDragEnter"
        PreviewDragOver="OnWindowPreviewDragOver"
        PreviewDrop="OnWindowPreviewDrop">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis"/>
        <conv:VideoBackendToBoolConverter x:Key="BackendToBool"/>
    </Window.Resources>

    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══ TOP TOOLBAR ═══ -->
        <Border Grid.Row="0" Background="{DynamicResource BgSecondaryBrush}"
                BorderBrush="{DynamicResource BorderPrimaryBrush}" BorderThickness="0,0,0,1">
            <DockPanel LastChildFill="True" Margin="12,8">
                <!-- Logo -->
                <TextBlock Text="FlipsiColor" FontSize="18" FontWeight="Bold"
                           Foreground="{DynamicResource AccentPrimaryBrush}"
                           VerticalAlignment="Center" Margin="0,0,24,0"/>

                <!-- Modus-Umschalter -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,24,0">
                    <RadioButton GroupName="MainMode"
                                 Content="{Binding ., Converter={StaticResource Loc}, ConverterParameter='Toolbar.Bild'}"
                                 IsChecked="True"
                                 Padding="12,6" Margin="0,0,4,0" Cursor="Hand"
                                 Checked="OnBildModeChecked"/>
                    <RadioButton GroupName="MainMode"
                                 Content="{Binding ., Converter={StaticResource Loc}, ConverterParameter='Toolbar.Video'}"
                                 Padding="12,6" Margin="0,0,4,0" Cursor="Hand"
                                 Checked="OnVideoModeChecked"/>
                    <RadioButton GroupName="MainMode"
                                 Content="{Binding ., Converter={StaticResource Loc}, ConverterParameter='Toolbar.Clips'}"
                                 Padding="12,6" Cursor="Hand"
                                 Checked="OnClipsModeChecked"/>
                </StackPanel>

                <!-- Rechts: Öffnen + Export + Theme + Sprache + GPU -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                            HorizontalAlignment="Right" DockPanel.Dock="Right">
                    <!-- Öffnen Button -->
                    <Button Content="{Binding ., Converter={StaticResource Loc}, ConverterParameter='Toolbar.DateiOeffnen'}"
                            Command="{Binding OeffnenCommand}"
                            Padding="12,6" Margin="0,0,8,0" Cursor="Hand"/>

                    <!-- Export Button -->
                    <Button Content="{Binding ., Converter={StaticResource Loc}, ConverterParameter='Toolbar.Export'}"
                            Command="{Binding ExportCommand}"
                            Padding="12,6" Margin="0,0,8,0" Cursor="Hand"
                            Visibility="{Binding BildGeladen, Converter={StaticResource BoolToVis}}"/>

                    <!-- Sprache-Umschalter -->
                    <ComboBox x:Name="SpracheComboBox" Width="90" Margin="0,0,8,0"
                              SelectedIndex="{Binding SpracheIndex}"
                              SelectionChanged="OnSpracheChanged" Cursor="Hand">
                        <ComboBoxItem Content="DE"/>
                        <ComboBoxItem Content="EN"/>
                        <ComboBoxItem Content="ES"/>
                        <ComboBoxItem Content="FR"/>
                        <ComboBoxItem Content="IT"/>
                        <ComboBoxItem Content="NL"/>
                        <ComboBoxItem Content="PL"/>
                        <ComboBoxItem Content="PT"/>
                        <ComboBoxItem Content="TR"/>
                        <ComboBoxItem Content="RU"/>
                        <ComboBoxItem Content="ZH"/>
                        <ComboBoxItem Content="JA"/>
                        <ComboBoxItem Content="KO"/>
                    </ComboBox>

                    <!-- Theme-Umschalter -->
                    <ComboBox x:Name="ThemeComboBox" Width="100" Margin="0,0,8,0"
                              SelectionChanged="OnThemeChanged" Cursor="Hand">
                        <ComboBoxItem Content="{Binding ., Converter={StaticResource Loc}, ConverterParameter='Theme.Light'}"/>
                        <ComboBoxItem Content="{Binding ., Converter={StaticResource Loc}, ConverterParameter='Theme.Dark'}"/>
                        <ComboBoxItem Content="{Binding ., Converter={StaticResource Loc}, ConverterParameter='Theme.System'}"/>
                    </ComboBox>

                    <!-- GPU-Status -->
                    <Border Background="{DynamicResource BgTertiaryBrush}" CornerRadius="4" Padding="8,4">
                        <TextBlock Text="{Binding GpuName}" FontSize="10"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                    </Border>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ═══ MAIN CONTENT ═══ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="280"/>
            </Grid.ColumnDefinitions>

            <!-- ═══ LEFT: Galerie ═══ -->
            <Border Grid.Column="0" Background="{DynamicResource BgSecondaryBrush}"
                    BorderBrush="{DynamicResource BorderPrimaryBrush}" BorderThickness="0,0,1,0"
                    AllowDrop="True" Drop="OnGalerieDrop" DragOver="OnDragOverAny" DragEnter="OnDragEnterAny">
                <DockPanel LastChildFill="True">
                    <StackPanel DockPanel.Dock="Top" Margin="12,12,12,4">
                        <TextBlock Text="{Binding ., Converter={StaticResource Loc}, ConverterParameter='Galerie.Titel'}"
                                   FontWeight="SemiBold" FontSize="13" Margin="0,0,0,4"/>
                        <TextBlock FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8">
                            <Run Text="{Binding DateiListe.Count, Mode=OneWay}"/>
                            <Run Text=" · "/>
                            <Run Text="{Binding ., Converter={StaticResource Loc}, ConverterParameter='Galerie.Titel'}"/>
                        </TextBlock>
                        <TextBlock Text="{Binding ., Converter={StaticResource Loc}, ConverterParameter='Galerie.Hinweis'}"
                                   FontSize="9" Foreground="{DynamicResource TextSecondaryBrush}"
                                   TextWrapping="Wrap" Margin="0,0,0,8" Opacity="0.7"/>
                    </StackPanel>

                    <!-- Galerie List -->
                    <ListBox ItemsSource="{Binding DateiListe}"
                             x:Name="GalerieListe"
                             SelectionChanged="OnGalerieSelectionChanged"
                             Background="Transparent" BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             Margin="4,0,4,8">
                        <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="2" Cursor="Hand">
                                <Border Width="190" Height="100"
                                        Background="{DynamicResource BgTertiaryBrush}"
                                        CornerRadius="4">
                                    <!-- Live Thumbnail Vorschau — Uniform statt UniformToFill damit nichts abgeschnitten wird -->
                                    <Image Source="{Binding Thumbnail}" Stretch="Uniform"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="{Binding Dateiname}" FontSize="10"
                                           TextTrimming="CharacterEllipsis"
                                           Margin="0,4,0,0" HorizontalAlignment="Center"/>
                                <TextBlock FontSize="9" Foreground="{DynamicResource TextSecondaryBrush}"
                                           HorizontalAlignment="Center">
                                    <Run Text="{Binding Typ, Mode=OneWay}"/>
                                    <Run Text=" · "/>
                                    <Run Text="{Binding Groesse, Mode=OneWay}"/>
                                </TextBlock>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- ═══ CENTER: Bildvorschau / Drop-Zone ═══ -->
            <Border Grid.Column="1" Background="{DynamicResource BgPrimaryBrush}"
                    BorderBrush="{DynamicResource BorderPrimaryBrush}" BorderThickness="1,0,1,0"
                    x:Name="DropZone"
                    AllowDrop="True"
                    Drop="OnDropZoneDrop"
                    DragEnter="OnDragEnterAny"
                    DragOver="OnDragOverAny"
                    DragLeave="OnDragLeaveAny">
                <Grid>
                    <!-- Bild-Vorschau -->
                    <Image Source="{Binding PipelineBild}" Stretch="Uniform"
                           VerticalAlignment="Center" HorizontalAlignment="Center"
                           Margin="16"/>

                    <!-- Platzhalter -->
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                Visibility="{Binding BildGeladen, Converter={StaticResource InverseBoolToVis}}">
                        <TextBlock Text="{Binding ., Converter={StaticResource Loc}, ConverterParameter='DropZone.Platzhalter'}"
                                   FontSize="16" Foreground="{DynamicResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding ., Converter={StaticResource Loc}, ConverterParameter='DropZone.Hinweis'}"
                                   FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center" Margin="0,0,0,12" Opacity="0.7"/>
                        <TextBlock Text="{Binding ., Converter={StaticResource Loc}, ConverterParameter='DropZone.FormateTitel'}"
                                   FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding ., Converter={StaticResource Loc}, ConverterParameter='DropZone.FormateListe'}"
                                   FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center" Opacity="0.6"/>
                    </StackPanel>

                    <!-- Pipeline-Ladebalken -->
                    <Border VerticalAlignment="Bottom" HorizontalAlignment="Center"
                            Margin="16" Padding="16,8"
                            Background="{DynamicResource BgSecondaryBrush}"
                            CornerRadius="8"
                            Visibility="{Binding PipelineLaeuft, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <TextBlock Text="{Binding ., Converter={StaticResource Loc}, ConverterParameter='DropZone.PipelineLaueft'}"
                                       FontSize="12" HorizontalAlignment="Center"
                                       Foreground="{DynamicResource AccentPrimaryBrush}"/>
                            <ProgressBar Height="4" Width="200" IsIndeterminate="True"
                                          Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- ═══ RIGHT: Korrektur-Panel ═══ -->
            <Border Grid.Column="2" Background="{DynamicResource BgSecondaryBrush}"
                    BorderBrush="{DynamicResource BorderPrimaryBrush}" BorderThickness="1,0,0,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0">
                    <StackPanel Margin="16,12">

                        <!-- ═══ Korrektur-Sliders ═══ -->
                        <TextBlock Text="{Binding ., Converter={StaticResource Loc}, ConverterParameter='Korrektur.Titel'}"
                                   FontSize="16" FontWeight="Bold" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding ., Converter={StaticResource Loc}, ConverterParameter='Korrektur.Beschreibung'}"
                                   FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,0,0,12"/>

                        <Expander IsExpanded="True" Margin="0,0,0,8"
                                  Header="{Binding ., Converter={StaticResource Loc}, ConverterParameter='Korrektur.TonExpander'}">
                            <StackPanel Margin="0,8,0,0">
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="35"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding ., Converter={StaticResource Loc}, ConverterParameter='Korrektur.Belichtung'}" VerticalAlignment="Center" FontSize="11"/>
                                    <Slider Grid.Column="1" Minimum="-100" Maximum="100" Value="{Binding Belichtung}" VerticalAlignment="Center" Margin="8,0"/>
                                    <TextBlock Grid.Column="2" Text="{Binding Belichtung, StringFormat='{}{0:F0}'}" VerticalAlignment="Center" HorizontalAlignment="Right" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                                </Grid>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="35"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding ., Converter={StaticResource Loc}, ConverterParameter='Korrektur.Kontrast'}" VerticalAlignment="Center" FontSize="11"/>
                                    <Slider Grid.Column="1" Minimum="-100" Maximum="100" Value="{Binding Kontrast}" VerticalAlignment="Center" Margin="8,0"/>
                                    <TextBlock Grid.Column="2" Text="{Binding Kontrast, StringFormat='{}{0:F0}'}" VerticalAlignment="Center" HorizontalAlignment="Right" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                                </Grid>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="35"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding ., Converter={StaticResource Loc}, ConverterParameter='Korrektur.Lichter'}" VerticalAlignment="Center" FontSize="11"/>
                                    <Slider Grid.Column="1" Minimum="-100" Maximum="100" Value="{Binding Lichter}" VerticalAlignment="Center" Margin="8,0"/>
                                    <TextBlock Grid.Column="2" Text="{Binding Lichter, StringFormat='{}{0:F0}'}" VerticalAlignment="Center" HorizontalAlignment="Right" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                                </Grid>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="35"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding ., Converter={StaticResource Loc}, ConverterParameter='Korrektur.Schatten'}" VerticalAlignment="Center" FontSize="11"/>
                                    <Slider Grid.Column="1" Minimum="-100" Maximum="100" Value="{Binding Schatten}" VerticalAlignment="Center" Margin="8,0"/>
                                    <TextBlock Grid.Column="2" Text="{Binding Schatten, StringFormat='{}{0:F0}'}" VerticalAlignment="Center" HorizontalAlignment="Right" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                                </Grid>
                            </StackPanel>
                        </Expander>

                        <Expander IsExpanded="True" Margin="0,0,0,8"
                                  Header="{Binding ., Converter={StaticResource Loc}, ConverterParameter='Korrektur.FarbeExpander'}">
                            <StackPanel Margin="0,8,0,0">
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="35"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding ., Converter={StaticResource Loc}, ConverterParameter='Korrektur.Saettigung'}" VerticalAlignment="Center" FontSize="11"/>
                                    <Slider Grid.Column="1" Minimum="-100" Maximum="100" Value="{Binding Saettigung}" VerticalAlignment="Center" Margin="8,0"/>
                                    <TextBlock Grid.Column="2" Text="{Binding Saettigung, StringFormat='{}{0:F0}'}" VerticalAlignment="Center" HorizontalAlignment="Right" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                                </Grid>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="35"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding ., Converter={StaticResource Loc}, ConverterParameter='Korrektur.Vibranz'}" VerticalAlignment="Center" FontSize="11"/>
                                    <Slider Grid.Column="1" Minimum="-100" Maximum="100" Value="{Binding Vibranz}" VerticalAlignment="Center" Margin="8,0"/>
                                    <TextBlock Grid.Column="2" Text="{Binding Vibranz, StringFormat='{}{0:F0}'}" VerticalAlignment="Center" HorizontalAlignment="Right" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                                </Grid>
                            </StackPanel>
                        </Expander>

                        <Expander IsExpanded="False" Margin="0,0,0,8"
                                  Header="{Binding ., Converter={StaticResource Loc}, ConverterParameter='Korrektur.DetailExpander'}">
                            <StackPanel Margin="0,8,0,0">
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="35"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding ., Converter={StaticResource Loc}, ConverterParameter='Korrektur.Schaerfe'}" VerticalAlignment="Center" FontSize="11"/>
                                    <Slider Grid.Column="1" Minimum="0" Maximum="100" Value="{Binding Schaerfe}" VerticalAlignment="Center" Margin="8,0"/>
                                    <TextBlock Grid.Column="2" Text="{Binding Schaerfe, StringFormat='{}{0:F0}'}" VerticalAlignment="Center" HorizontalAlignment="Right" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                                </Grid>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="35"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding ., Converter={StaticResource Loc}, ConverterParameter='Korrektur.RauschenLuma'}" VerticalAlignment="Center" FontSize="11"/>
                                    <Slider Grid.Column="1" Minimum="0" Maximum="100" Value="{Binding RauschenLuma}" VerticalAlignment="Center" Margin="8,0"/>
                                    <TextBlock Grid.Column="2" Text="{Binding RauschenLuma, StringFormat='{}{0:F0}'}" VerticalAlignment="Center" HorizontalAlignment="Right" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                                </Grid>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="35"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding ., Converter={StaticResource Loc}, ConverterParameter='Korrektur.RauschenChroma'}" VerticalAlignment="Center" FontSize="11"/>
                                    <Slider Grid.Column="1" Minimum="0" Maximum="100" Value="{Binding RauschenChroma}" VerticalAlignment="Center" Margin="8,0"/>
                                    <TextBlock Grid.Column="2" Text="{Binding RauschenChroma, StringFormat='{}{0:F0}'}" VerticalAlignment="Center" HorizontalAlignment="Right" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                                </Grid>
                            </StackPanel>
                        </Expander>

                        <!-- Objektivkorrektur -->
                        <CheckBox Content="{Binding ., Converter={StaticResource Loc}, ConverterParameter='Objektiv.Titel'}"
                                  IsChecked="{Binding Objektivkorrektur}"
                                  Margin="0,4,0,8" Cursor="Hand"/>
                        <TextBlock Text="{Binding ., Converter={StaticResource Loc}, ConverterParameter='Objektiv.Beschreibung'}"
                                   FontSize="9" Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,0,0,4" Opacity="0.6"/>

                        <!-- Kamera & Objektiv manuell wählen (nur sichtbar wenn Objektivkorrektur aktiv) -->
                        <Expander IsExpanded="False" Margin="0,0,0,12"
                                  Header="{Binding ., Converter={StaticResource Loc}, ConverterParameter='Objektiv.Expander'}"
                                  Visibility="{Binding Objektivkorrektur, Converter={StaticResource BoolToVis}}"
                                  Cursor="Hand">
                            <StackPanel Margin="0,4,0,0">
                                <TextBlock Text="{Binding ., Converter={StaticResource Loc}, ConverterParameter='Objektiv.KameraHersteller'}" FontSize="11" Margin="0,0,0,4"/>
                                <ComboBox ItemsSource="{Binding VerfuegbareKameras}"
                                          SelectedItem="{Binding AusgewaehlteKamera}"
                                          Margin="0,0,0,8" Cursor="Hand"/>

                                <TextBlock Text="{Binding ., Converter={StaticResource Loc}, ConverterParameter='Objektiv.Objektiv'}" FontSize="11" Margin="0,0,0,4"/>
                                <ComboBox ItemsSource="{Binding VerfuegbareObjektive}"
                                          SelectedItem="{Binding AusgewaehltesObjektiv}"
                                          Margin="0,0,0,8" Cursor="Hand"/>

                                <TextBlock Text="{Binding ., Converter={StaticResource Loc}, ConverterParameter='Objektiv.LeerAuto'}"
                                           FontSize="9" Foreground="{DynamicResource TextSecondaryBrush}"
                                           Margin="0,0,0,4" Opacity="0.6"/>
                            </StackPanel>
                        </Expander>

                        <!-- ═══ KI-Einstellungen ═══ -->
                        <Border Background="{DynamicResource BgTertiaryBrush}" CornerRadius="8" Padding="12" Margin="0,8,0,12">
                            <StackPanel>
                                <TextBlock Text="{Binding ., Converter={StaticResource Loc}, ConverterParameter='KI.Titel'}" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding ., Converter={StaticResource Loc}, ConverterParameter='KI.Beschreibung'}"
                                           FontSize="9" Foreground="{DynamicResource TextSecondaryBrush}"
                                           Margin="0,0,0,8"/>

                                <!-- Modus -->
                                <TextBlock Text="{Binding ., Converter={StaticResource Loc}, ConverterParameter='KI.Modus'}" FontSize="11" Margin="0,0,0,4"/>
                                <ComboBox SelectedValuePath="Content"
                                          SelectedValue="{Binding AktuellerModus}"
                                          Margin="0,0,0,4" Cursor="Hand">
                                    <ComboBoxItem Content="Ask"/>
                                    <ComboBoxItem Content="SmartLearn"/>
                                    <ComboBoxItem Content="Turbo"/>
                                </ComboBox>
                                <TextBlock Text="{Binding ., Converter={StaticResource Loc}, ConverterParameter='KI.ModusBeschreibung'}"
                                           FontSize="9" Foreground="{DynamicResource TextSecondaryBrush}"
                                           Margin="0,0,0,8" Opacity="0.6"/>

                                <!-- Intensität -->
                                <TextBlock Text="{Binding ., Converter={StaticResource Loc}, ConverterParameter='KI.Intensitaet'}" FontSize="11" Margin="0,0,0,4"/>
                                <ComboBox SelectedIndex="{Binding IntensitaetIndex}"
                                          Margin="0,0,0,8" Cursor="Hand">
                                    <ComboBoxItem Content="{Binding ., Converter={StaticResource Loc}, ConverterParameter='Intensitaet.Leicht'}"/>
                                    <ComboBoxItem Content="{Binding ., Converter={StaticResource Loc}, ConverterParameter='Intensitaet.Mittel'}"/>
                                    <ComboBoxItem Content="{Binding ., Converter={StaticResource Loc}, ConverterParameter='Intensitaet.Stark'}"/>
                                </ComboBox>

                                <!-- Upscaling -->
                                <TextBlock Text="{Binding ., Converter={StaticResource Loc}, ConverterParameter='KI.Hochskalieren'}" FontSize="11" Margin="0,0,0,4"/>
                                <ComboBox SelectedIndex="{Binding HochskalierenFaktor}"
                                          Margin="0,0,0,4" Cursor="Hand">
                                    <ComboBoxItem Content="{Binding ., Converter={StaticResource Loc}, ConverterParameter='Upscale.Aus'}"/>
                                    <ComboBoxItem Content="{Binding ., Converter={StaticResource Loc}, ConverterParameter='Upscale.2x'}"/>
                                    <ComboBoxItem Content="{Binding ., Converter={StaticResource Loc}, ConverterParameter='Upscale.3x'}"/>
                                    <ComboBoxItem Content="{Binding ., Converter={StaticResource Loc}, ConverterParameter='Upscale.4x'}"/>
                                </ComboBox>
                                <TextBlock Text="{Binding ., Converter={StaticResource Loc}, ConverterParameter='KI.HochskalierenBeschreibung'}"
                                           FontSize="9" Foreground="{DynamicResource TextSecondaryBrush}"
                                           Margin="0,0,0,8" Opacity="0.6"/>

                                <!-- Gesichtswiederherstellung -->
                                <CheckBox Content="{Binding ., Converter={StaticResource Loc}, ConverterParameter='KI.Gesichtswiederherstellung'}"
                                          IsChecked="{Binding GesichtswiederherstellungAktiv}"
                                          Cursor="Hand" Margin="0,4,0,4"
                                          TextBlock.FontSize="11"/>
                                <TextBlock Text="{Binding ., Converter={StaticResource Loc}, ConverterParameter='KI.GesichtBeschreibung'}"
                                           FontSize="9" Foreground="{DynamicResource TextSecondaryBrush}"
                                           Margin="0,0,0,8" Opacity="0.6"/>

                                <!-- Style-LUT -->
                                <TextBlock Text="{Binding ., Converter={StaticResource Loc}, ConverterParameter='KI.StyleLUT'}" FontSize="11" Margin="0,4,0,4"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <Button Content="{Binding ., Converter={StaticResource Loc}, ConverterParameter='KI.Laden'}"
                                            Command="{Binding StyleLutLadenCommand}"
                                            Padding="6,3" FontSize="11" Margin="0,0,4,0" Cursor="Hand"/>
                                    <Button Content="{Binding ., Converter={StaticResource Loc}, ConverterParameter='KI.Entfernen'}"
                                            Command="{Binding StyleLutEntfernenCommand}"
                                            Padding="6,3" FontSize="11" Cursor="Hand"/>
                                </StackPanel>
                                <TextBlock Text="{Binding StyleLutName}" FontSize="10"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           Margin="0,0,0,8"/>
                            </StackPanel>
                        </Border>

                        <!-- ═══ Buttons ═══ -->
                        <Button Content="{Binding ., Converter={StaticResource Loc}, ConverterParameter='Pipeline.Starten'}"
                                Command="{Binding PipelineAusfuehrenCommand}"
                                Padding="12,8" Margin="0,0,0,8" Cursor="Hand"
                                IsEnabled="{Binding BildGeladen}"/>
                        <TextBlock Text="{Binding ., Converter={StaticResource Loc}, ConverterParameter='Pipeline.Beschreibung'}"
                                   FontSize="9" Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,0,0,8" Opacity="0.6"/>
                        <Button Content="{Binding ., Converter={StaticResource Loc}, ConverterParameter='Pipeline.Zuruecksetzen'}"
                                Command="{Binding ZuruecksetzenCommand}"
                                Padding="12,8" Margin="0,0,0,8" Cursor="Hand"/>

                        <!-- Video-Backend (nur im Video-Modus) -->
                        <StackPanel Margin="0,8,0,0" x:Name="VideoBackendPanel" Visibility="Collapsed">
                            <TextBlock Text="{Binding ., Converter={StaticResource Loc}, ConverterParameter='Video.Backend.Titel'}" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding ., Converter={StaticResource Loc}, ConverterParameter='Video.Backend.Beschreibung'}"
                                       FontSize="9" Foreground="{DynamicResource TextSecondaryBrush}"
                                       Margin="0,0,0,8" Opacity="0.6"/>
                            <RadioButton GroupName="VideoBackend"
                                        Content="{Binding ., Converter={StaticResource Loc}, ConverterParameter='Video.Backend.FFmpeg'}"
                                        IsChecked="{Binding VideoBackend, Converter={StaticResource BackendToBool}, ConverterParameter=FFmpeg, Mode=TwoWay}"
                                        Margin="0,0,0,4" Cursor="Hand"/>
                            <RadioButton GroupName="VideoBackend"
                                        Content="{Binding ., Converter={StaticResource Loc}, ConverterParameter='Video.Backend.VapourSynth'}"
                                        IsChecked="{Binding VideoBackend, Converter={StaticResource BackendToBool}, ConverterParameter=VapourSynth, Mode=TwoWay}"
                                        Margin="0,0,0,8" Cursor="Hand"/>
                            <!-- Installations-UI: sichtbar wenn VapourSynth gewählt aber NICHT installiert -->
                            <!-- Auto-Installation startet beim Umschalten automatisch -->
                            <!-- Button bleibt als manueller Fallback -->
                            <Border Background="{DynamicResource BgTertiaryBrush}" CornerRadius="8" Padding="12" Margin="0,0,0,8"
                                    Visibility="{Binding VapourSynthInstallUiSichtbar, Converter={StaticResource BoolToVis}}">
                                <StackPanel>
                                    <ProgressBar Value="{Binding InstallationsFortschritt}" Maximum="100" Height="6"
                                                 Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding InstallationsText}" FontSize="10"
                                               Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"
                                               Margin="0,0,0,8"/>
                                    <Button Content="{Binding ., Converter={StaticResource Loc}, ConverterParameter='Video.Backend.ErneutInstallieren'}"
                                            Command="{Binding InstalliereVapourSynthCommand}"
                                            Padding="8,4" FontSize="11" Cursor="Hand"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- ═══ BOTTOM STATUS-BAR ═══ -->
        <Border Grid.Row="2" Background="{DynamicResource BgSecondaryBrush}"
                BorderBrush="{DynamicResource BorderPrimaryBrush}" BorderThickness="0,1,0,0">
            <DockPanel LastChildFill="True" Margin="12,6">
                <TextBlock Text="{Binding StatusText}" FontSize="11"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Right">
                    <StackPanel Orientation="Horizontal"
                                Visibility="{Binding UpdateVerfuegbar, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{Binding ., Converter={StaticResource Loc}, ConverterParameter='Status.UpdateVerfuegbar'}" FontSize="11"
                                   Foreground="{DynamicResource AccentSecondaryBrush}"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="{Binding NeueVersion}" FontSize="11"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <Button Content="{Binding ., Converter={StaticResource Loc}, ConverterParameter='Status.Installieren'}"
                                Command="{Binding UpdateStartenCommand}"
                                Padding="8,3" FontSize="10" Margin="0,0,4,0" Cursor="Hand"/>
                    </StackPanel>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>