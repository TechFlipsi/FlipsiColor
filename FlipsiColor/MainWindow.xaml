<Window x:Class="FlipsiColor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:FlipsiColor.UI"
        Title="{Binding Title}"
        Width="1200" Height="800"
        WindowStartupLocation="CenterScreen"
        MinWidth="800" MinHeight="600">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <!-- ═══ Sidebar ═══ -->
        <Border Grid.Column="0" Background="{DynamicResource BgSecondaryBrush}"
                BorderBrush="{DynamicResource BorderPrimaryBrush}" BorderThickness="0,0,1,0">
            <StackPanel Margin="16">
                <!-- Logo -->
                <TextBlock Text="FlipsiColor" FontSize="24" FontWeight="Bold"
                           Foreground="{DynamicResource AccentPrimaryBrush}" Margin="0,0,0,24"/>

                <!-- Tab-Steuerung -->
                <TextBlock Text="Ansicht" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <TabControl x:Name="MainTabs" Margin="0,0,0,16"
                           BorderThickness="0" Padding="0"
                           Background="Transparent">
                    <TabControl.Resources>
                        <Style TargetType="TabItem">
                            <Setter Property="Padding" Value="8,4"/>
                            <Setter Property="FontSize" Value="12"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                        </Style>
                    </TabControl.Resources>

                    <!-- ═══ TAB 1: Bild-Korrektur ═══ -->
                    <TabItem Header="🎨 Bild">
                        <StackPanel Margin="0,8,0,0">
                            <!-- Modus -->
                            <TextBlock Text="Modus" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <ComboBox SelectedValuePath="Content"
                                      SelectedValue="{Binding AktuellerModus}"
                                      Margin="0,0,0,16">
                                <ComboBoxItem Content="Ask"/>
                                <ComboBoxItem Content="SmartLearn"/>
                                <ComboBoxItem Content="Turbo"/>
                            </ComboBox>

                            <!-- Intensität -->
                            <TextBlock Text="Intensität" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <ComboBox SelectedIndex="{Binding IntensitaetIndex}" Margin="0,0,0,16">
                                <ComboBoxItem Content="Leicht"/>
                                <ComboBoxItem Content="Mittel"/>
                                <ComboBoxItem Content="Stark"/>
                            </ComboBox>

                            <!-- Buttons -->
                            <Button Content="📁 Bild öffnen" Command="{Binding BildOeffnenCommand}" Margin="0,0,0,8"/>
                            <Button Content="▶ Pipeline starten" Command="{Binding PipelineAusfuehrenCommand}" Margin="0,0,0,8"/>
                            <Button Content="↺ Zurücksetzen" Command="{Binding ZuruecksetzenCommand}" Margin="0,0,0,8"/>

                            <!-- Upscaling -->
                            <TextBlock Text="Hochskalieren" FontWeight="SemiBold" Margin="0,8,0,4"/>
                            <ComboBox SelectedIndex="{Binding HochskalierenFaktor}" Margin="0,0,0,8">
                                <ComboBoxItem Content="Aus (1x)"/>
                                <ComboBoxItem Content="2x (RealESRGAN)"/>
                                <ComboBoxItem Content="3x"/>
                                <ComboBoxItem Content="4x"/>
                            </ComboBox>

                            <!-- Gesichtswiederherstellung -->
                            <CheckBox Content="👤 Gesichtswiederherstellung (CodeFormer)"
                                      IsChecked="{Binding GesichtswiederherstellungAktiv}"
                                      TextBlock.FontSize="11"
                                      Margin="0,4,0,8"/>

                            <!-- StyleLUT -->
                            <TextBlock Text="Style-LUT" FontWeight="SemiBold" Margin="0,4,0,4"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <Button Content="📂 Laden" Command="{Binding StyleLutLadenCommand}"
                                        Padding="6,3" FontSize="11" Margin="0,0,4,0"/>
                                <Button Content="✕ Entfernen" Command="{Binding StyleLutEntfernenCommand}"
                                        Padding="6,3" FontSize="11"/>
                            </StackPanel>
                            <TextBlock Text="{Binding StyleLutName}" FontSize="10"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Margin="0,0,0,8"/>

                            <!-- Distortion Grid -->
                            <CheckBox Content="🔲 Distortion Grid"
                                      IsChecked="{Binding DistortionGridAktiv}"
                                      Margin="0,8,0,4"/>
                            <Button Content="Kalibrieren"
                                    Command="{Binding DistortionGridKalibrierenCommand}"
                                    Padding="8,4" FontSize="11" Margin="0,0,0,8"/>

                            <!-- Color Calibration -->
                            <CheckBox Content="🎨 Color Calibration"
                                      IsChecked="{Binding ColorCalibrationAktiv}"
                                      Margin="0,4,0,4"/>
                            <Button Content="Kalibrieren"
                                    Command="{Binding ColorCalibrationKalibrierenCommand}"
                                    Padding="8,4" FontSize="11" Margin="0,0,0,8"/>

                            <!-- Progress -->
                            <ProgressBar Height="4"
                                         IsIndeterminate="True"
                                         Visibility="{Binding PipelineLaeuft, Converter={StaticResource BoolToVis}}"
                                         Margin="0,4,0,4"/>
                        </StackPanel>
                    </TabItem>

                    <!-- ═══ TAB 2: Video ═══ -->
                    <TabItem Header="🎬 Video">
                        <StackPanel Margin="0,8,0,0">
                            <TextBlock Text="Video-Pipeline" FontWeight="Bold" FontSize="14" Margin="0,0,0,4"/>
                            <TextBlock TextWrapping="Wrap" FontSize="11"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,12">
                                Video-Farbkorrektur mit Szenenwechsel-Erkennung und Audio-Erhaltung.
                            </TextBlock>

                            <!-- Video öffnen -->
                            <Button Content="🎬 Video öffnen" Command="{Binding VideoOeffnenCommand}" Margin="0,0,0,8"/>
                            <TextBlock Text="{Binding VideoPfad}" FontSize="10"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       TextWrapping="Wrap" Margin="0,0,0,8"/>
                            <TextBlock Text="{Binding VideoInfo}" FontSize="10"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Margin="0,0,0,12"/>

                            <!-- Pipeline starten -->
                            <Button Content="▶ Video-Pipeline starten"
                                    Command="{Binding VideoPipelineAusfuehrenCommand}"
                                    Margin="0,0,0,8"/>

                            <!-- Fortschritts-Bar -->
                            <ProgressBar Value="{Binding VideoFortschritt}" Maximum="1" Height="6"
                                         Visibility="{Binding VideoPipelineLaeuft, Converter={StaticResource BoolToVis}}"
                                         Margin="0,4,0,4"/>
                        </StackPanel>
                    </TabItem>

                    <!-- ═══ TAB 3: Clips zusammenfügen ═══ -->
                    <TabItem Header="🔗 Clips zusammenfügen">
                        <StackPanel Margin="0,8,0,0">
                            <TextBlock Text="Clips zusammenfügen" FontWeight="Bold" FontSize="14" Margin="0,0,0,4"/>
                            <TextBlock TextWrapping="Wrap" FontSize="11"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,12">
                                Fügt Video-Clips automatisch zusammen. Kameras teilen Aufnahmen in neue Dateien.
                            </TextBlock>

                            <!-- Ordner auswählen -->
                            <Button Content="📂 Ordner auswählen" Command="{Binding ClipOrdnerOeffnenCommand}" Margin="0,0,0,8"/>
                            <TextBlock Text="{Binding ClipOrdner}" FontSize="10"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       TextWrapping="Wrap" Margin="0,0,0,12"/>

                            <!-- Farbkorrektur Toggle -->
                            <Border Background="{DynamicResource BgTertiaryBrush}" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                                <StackPanel>
                                    <CheckBox Content="Farbkorrektur nach Zusammenfügen"
                                              IsChecked="{Binding ClipMergeFarbkorrekturAktiv}"
                                              FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <TextBlock TextWrapping="Wrap" FontSize="10"
                                               Foreground="{DynamicResource TextSecondaryBrush}">
                                An: Clips werden zusammengefügt UND farbkorrigiert. Aus: Nur Zusammenfügen.
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <!-- Clip-Gruppen Liste -->
                            <TextBlock Text="Erkannte Clip-Gruppen:" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <ListBox ItemsSource="{Binding ClipGruppen}"
                                     SelectedItem="{Binding AusgewaehlteGruppe}"
                                     Height="120" Margin="0,0,0,8">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="2">
                                            <TextBlock Text="{Binding GruppenName}" FontWeight="SemiBold" FontSize="11"/>
                                            <TextBlock FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}">
                                                <Run Text="{Binding ClipAnzahl, Mode=OneWay}"/>
                                                <Run Text=" Clips · "/>
                                                <Run Text="{Binding GesamtGroesse, Mode=OneWay}"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <!-- Merge Buttons -->
                            <Button Content="🔗 Ausgewählte zusammenfügen"
                                    Command="{Binding ClipMergeAusfuehrenCommand}"
                                    Margin="0,0,0,8"/>
                            <Button Content="🔗 Alle zusammenfügen"
                                    Command="{Binding ClipAlleMergenCommand}"
                                    Margin="0,0,0,8"/>

                            <!-- Merge Progress -->
                            <ProgressBar Value="{Binding ClipMergeFortschritt}" Maximum="1" Height="6"
                                         Visibility="{Binding ClipMergeLaeuft, Converter={StaticResource BoolToVis}}"
                                         Margin="0,4,0,4"/>
                        </StackPanel>
                    </TabItem>
                </TabControl>

                <!-- GPU Info -->
                <Border Background="{DynamicResource BgTertiaryBrush}" CornerRadius="8" Padding="12" Margin="0,8,0,0">
                    <StackPanel>
                        <TextBlock Text="GPU" FontWeight="SemiBold" FontSize="12"/>
                        <TextBlock Text="{Binding GpuName}" FontSize="11"
                                   Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                        <Ellipse Width="8" Height="8" Margin="0,4,0,0" HorizontalAlignment="Left">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="{DynamicResource SuccessBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding GpuVerfuegbar}" Value="False">
                                            <Setter Property="Fill" Value="{DynamicResource WarningBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                    </StackPanel>
                </Border>

                <!-- Update -->
                <Border Background="{DynamicResource BgTertiaryBrush}" CornerRadius="8" Padding="12" Margin="0,8,0,0"
                        Visibility="{Binding UpdateVerfuegbar, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <TextBlock Text="Update verfügbar!" FontWeight="SemiBold"
                                   Foreground="{DynamicResource AccentSecondaryBrush}"/>
                        <TextBlock Text="{Binding NeueVersion}" FontSize="11"/>
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <Button Content="Installieren" Command="{Binding UpdateStartenCommand}"
                                    Padding="8,4" Margin="0,0,8,0" FontSize="11"/>
                            <Button Content="Ignorieren" Command="{Binding UpdateIgnorierenCommand}"
                                    Padding="8,4" FontSize="11" Background="{DynamicResource BgTertiaryBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Theme -->
                <StackPanel Margin="0,16,0,0">
                    <TextBlock Text="Theme" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="☀ Light" Command="{Binding ThemeWechselnCommand}"
                                CommandParameter="Light" Padding="8,4" Margin="0,0,4,0" FontSize="11"/>
                        <Button Content="🌙 Dark" Command="{Binding ThemeWechselnCommand}"
                                CommandParameter="Dark" Padding="8,4" Margin="0,0,4,0" FontSize="11"/>
                        <Button Content="🖥 System" Command="{Binding ThemeWechselnCommand}"
                                CommandParameter="System" Padding="8,4" FontSize="11"/>
                    </StackPanel>
                </StackPanel>

                <!-- Status -->
                <TextBlock Text="{Binding StatusText}" FontSize="11"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           VerticalAlignment="Bottom" Margin="0,24,0,0"/>
            </StackPanel>
        </Border>

        <!-- ═══ Canvas Area ═══ -->
        <Border Grid.Column="1" Background="{DynamicResource BgPrimaryBrush}"
                AllowDrop="True"
                DragEnter="OnDragEnter"
                DragOver="OnDragOver"
                DragLeave="OnDragLeave"
                Drop="OnDrop"
                BorderBrush="{DynamicResource BorderPrimaryBrush}" BorderThickness="1">
            <Grid>
                <!-- Bild-Vorschau -->
                <Image Source="{Binding PipelineBild}" Stretch="Uniform"
                       VerticalAlignment="Center" HorizontalAlignment="Center"
                       Margin="16"/>

                <!-- Platzhalter -->
                <TextBlock Text="Bild öffnen oder Dateien hierher ziehen"
                           FontSize="18" Foreground="{DynamicResource TextSecondaryBrush}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Visibility="{Binding BildGeladen, Converter={StaticResource InverseBoolToVis}}"/>

                <!-- Dateiliste (Drag & Drop) -->
                <Border VerticalAlignment="Bottom" Margin="16"
                        Background="{DynamicResource BgSecondaryBrush}"
                        BorderBrush="{DynamicResource BorderPrimaryBrush}" BorderThickness="1"
                        CornerRadius="8"
                        Visibility="{Binding DateiListe.Count, Converter={StaticResource BoolToVis}}">
                    <StackPanel Margin="8">
                        <DockPanel Margin="0,0,0,4">
                            <TextBlock Text="Dateiliste" FontWeight="SemiBold" FontSize="12"/>
                            <Button Content="🗑 Liste leeren" Command="{Binding DateiListeLeerenCommand}"
                                    HorizontalAlignment="Right" Padding="6,2" FontSize="10"
                                    DockPanel.Dock="Right"/>
                        </DockPanel>
                        <ListBox ItemsSource="{Binding DateiListe}"
                                 MaxHeight="200" BorderThickness="0"
                                 Background="Transparent">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Dateiname}"
                                                   FontSize="11" VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Typ}"
                                                   FontSize="10" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   Margin="8,0,8,0"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Groesse}"
                                                   FontSize="10" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   Margin="0,0,8,0"/>
                                        <Button Grid.Column="3" Content="✕" Padding="4,2" FontSize="10"
                                                Command="{Binding DataContext.DateiEntfernenCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ═══ Adjustments Panel ═══ -->
        <Border Grid.Column="2" Background="{DynamicResource BgSecondaryBrush}"
                BorderBrush="{DynamicResource BorderPrimaryBrush}" BorderThickness="1,0,0,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="16">
                    <TextBlock Text="Korrektur" FontSize="18" FontWeight="Bold" Margin="0,0,0,16"/>

                    <!-- Belichtung -->
                    <TextBlock Text="Belichtung" Margin="0,0,0,4"/>
                    <Slider Minimum="-100" Maximum="100" Value="{Binding Belichtung}" Margin="0,0,0,12"/>

                    <!-- Kontrast -->
                    <TextBlock Text="Kontrast" Margin="0,0,0,4"/>
                    <Slider Minimum="-100" Maximum="100" Value="{Binding Kontrast}" Margin="0,0,0,12"/>

                    <!-- Sättigung -->
                    <TextBlock Text="Sättigung" Margin="0,0,0,4"/>
                    <Slider Minimum="-100" Maximum="100" Value="{Binding Saettigung}" Margin="0,0,0,12"/>

                    <!-- Vibranz -->
                    <TextBlock Text="Vibranz" Margin="0,0,0,4"/>
                    <Slider Minimum="-100" Maximum="100" Value="{Binding Vibranz}" Margin="0,0,0,12"/>

                    <!-- Lichter -->
                    <TextBlock Text="Lichter" Margin="0,0,0,4"/>
                    <Slider Minimum="-100" Maximum="100" Value="{Binding Lichter}" Margin="0,0,0,12"/>

                    <!-- Schatten -->
                    <TextBlock Text="Schatten" Margin="0,0,0,4"/>
                    <Slider Minimum="-100" Maximum="100" Value="{Binding Schatten}" Margin="0,0,0,12"/>

                    <!-- Schärfe -->
                    <TextBlock Text="Schärfe" Margin="0,0,0,4"/>
                    <Slider Minimum="0" Maximum="100" Value="{Binding Schaerfe}" Margin="0,0,0,12"/>

                    <!-- Luminanz-Rauschen -->
                    <TextBlock Text="Rauschen (Luma)" Margin="0,0,0,4"/>
                    <Slider Minimum="0" Maximum="100" Value="{Binding RauschenLuma}" Margin="0,0,0,12"/>

                    <!-- Chrominanz-Rauschen -->
                    <TextBlock Text="Rauschen (Chroma)" Margin="0,0,0,4"/>
                    <Slider Minimum="0" Maximum="100" Value="{Binding RauschenChroma}" Margin="0,0,0,12"/>

                    <!-- Objektivkorrektur -->
                    <CheckBox Content="Objektivkorrektur" IsChecked="{Binding Objektivkorrektur}" Margin="0,8,0,0"/>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>